          </div>
          <div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap">
            <button class="btn btn-ghost" onclick="applyRotate(-90)">↺ 90° Left</button>
            <button class="btn btn-ghost" onclick="applyRotate(90)">↻ 90° Right</button>
            <button class="btn btn-ghost" onclick="applyRotate(180)">↕ 180°</button>
          </div>
          <div class="control-group" style="margin-top:14px">
            <div class="control-label">Custom angle <span class="control-value" id="rot-angle-val">0°</span></div>
