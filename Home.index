          </div>
          <button class="btn btn-primary" style="width:100%;margin-top:4px" onclick="applyCustomRotate()">🔁 Apply Rotation</button>
        </div>
        <div>
          <div class="preview-box" id="prev-rotate"><div class="preview-placeholder"><span>🔁</span>Preview here</div></div>
          <div class="result-area" id="res-rotate">
