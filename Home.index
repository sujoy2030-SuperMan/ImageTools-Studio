</main>

<!-- FOOTER -->
<footer class="footer" role="contentinfo">
  <p><strong>ImageTools Studio</strong> — Free, fast, browser-based image processing. <span>No files are uploaded. Everything runs locally in your browser.</span></p>
  <p style="margin-top:8px">© 2025 ImageTools Studio · All rights reserved</p>
</footer>

<!-- TOAST -->
<div class="toast-wrap" id="toast-wrap" aria-live="polite"></div>

<script>
// ===== PDF.js CDN loader =====
let pdfjsLib = null;
function loadPdfJS(cb) {
  if (pdfjsLib) { cb(); return; }
  const s = document.createElement('script');
  s.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
  s.onload = () => {
    pdfjsLib = window['pdfjs-dist/build/pdf'];
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    cb();
  };
  s.onerror = () => toast('Failed to load PDF.js. Check your connection.','error');
  document.head.appendChild(s);
}

// ===== jsPDF CDN loader =====
let jsPDFLib = null;
function loadJsPDF(cb) {
  if (jsPDFLib) { cb(); return; }
  const s = document.createElement('script');
  s.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
  s.onload = () => { jsPDFLib = window.jspdf; cb(); };
  s.onerror = () => toast('Failed to load jsPDF. Check your connection.','error');
  document.head.appendChild(s);
}

// ===== STATE =====
const state = {
  compress: { img: null, origSize: 0 },
  resize: { img: null, origW: 0, origH: 0 },
  convert: { files: [], format: 'jpg' },
  crop: { img: null, sel: {x:0,y:0,w:0,h:0}, dragging: false, startX:0, startY:0, scaleX:1, scaleY:1 },
  rotate: { img: null, angle: 0 },
  flip: { img: null },
  watermark: { img: null },
  merge: { images: [], dir: 'horizontal' },
  pdf: { pages: [], format: 'jpg' },
  i2p: { images: [], orient: 'portrait', pdfBlob: null }
};

// ===== NAVIGATION =====
function scrollToTools() {
  document.getElementById('tools').scrollIntoView({behavior:'smooth'});
}

function openTool(name) {
  document.querySelectorAll('.workspace-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tool-card').forEach(c => c.classList.remove('active'));
  const panel = document.getElementById('panel-' + name);
  if (panel) {
    panel.classList.add('active');
    panel.scrollIntoView({behavior:'smooth', block:'start'});
    setTimeout(() => panel.scrollIntoView({behavior:'smooth', block:'start'}), 100);
  }
  const card = document.querySelector('[data-tool="' + name + '"]');
  if (card) card.classList.add('active');
}

function closeTool() {
  document.querySelectorAll('.workspace-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tool-card').forEach(c => c.classList.remove('active'));
}

// keyboard nav for tool cards
document.querySelectorAll('.tool-card').forEach(card => {
  card.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }});
});

// ===== DRAG & DROP global =====
function setupDragDrop(dzId, inputId) {

    const dz = document.getElementById(dzId);
    const input = document.getElementById(inputId);

    if (!dz || !input) return;

    ['dragenter', 'dragover'].forEach(eventName => {
        dz.addEventListener(eventName, e => {
            e.preventDefault();
            e.stopPropagation();
            dz.classList.add('drag-over');
        });
    });

    ['dragleave', 'drop'].forEach(eventName => {
        dz.addEventListener(eventName, e => {
            e.preventDefault();
            e.stopPropagation();
            dz.classList.remove('drag-over');
        });
    });

    dz.addEventListener('drop', e => {

        const files = e.dataTransfer.files;

        if (!files || files.length === 0) return;

        try {

            const dataTransfer = new DataTransfer();

            Array.from(files).forEach(file => {
                dataTransfer.items.add(file);
            });

            input.files = dataTransfer.files;

        } catch (err) {

            Object.defineProperty(input, 'files', {
                value: files,
                writable: false
            });

        }

        input.dispatchEvent(
            new Event('change', {
                bubbles: true
            })
        );

    });

}

// ===== TOAST =====
function toast(msg, type='info', duration=3500) {
  const w = document.getElementById('toast-wrap');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  const icons = {success:'✅',error:'❌',info:'ℹ️'};
  t.innerHTML = `<span>${icons[type]||'ℹ️'}</span><span>${msg}</span>`;
  w.appendChild(t);
  setTimeout(() => { t.style.animation = 'slideOut 0.3s ease forwards'; setTimeout(() => t.remove(), 300); }, duration);
}

// ===== UTILS =====
function fmtSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return (bytes/1024).toFixed(1) + ' KB';
  return (bytes/1048576).toFixed(2) + ' MB';
}

function loadImageFromFile(file) {
  return new Promise((res, rej) => {
    const url = URL.createObjectURL(file);
    const img = new Image();
    img.onload = () => { URL.revokeObjectURL(url); res(img); };
    img.onerror = rej;
    img.src = url;
  });
}

function readFileAsDataURL(file) {
  return new Promise((res, rej) => {
    const fr = new FileReader();
    fr.onload = e => res(e.target.result);
    fr.onerror = rej;
    fr.readAsDataURL(file);
  });
}

function canvasToBlob(canvas, type, quality) {
  return new Promise(res => canvas.toBlob(res, type, quality));
}

function downloadCanvas(canvasId, filename) {
  const cv = document.getElementById(canvasId);
  if (!cv || cv.width === 0) { toast('Nothing to download yet.','error'); return; }
  const ext = filename.split('.').pop().toLowerCase();
  const mimeMap = {jpg:'image/jpeg',jpeg:'image/jpeg',png:'image/png',webp:'image/webp'};
  const mime = mimeMap[ext] || 'image/png';
  const a = document.createElement('a');
  a.href = cv.toDataURL(mime, 0.92);
  a.download = filename;
  a.click();
  toast('Downloaded ' + filename,'success');
}

function showProcessing(id, show) {
  const el = document.getElementById(id);
  if (el) { el.classList.toggle('active', show); }
}

function setProgress(fillId, pct) {
  const el = document.getElementById(fillId);
  if (el) el.style.width = pct + '%';
}

function showResult(areaId) {
  const el = document.getElementById(areaId);
  if (el) el.classList.add('show');
}

function setPreviewImg(boxId, src) {
  const box = document.getElementById(boxId);
  if (!box) return;
  box.innerHTML = `<img src="${src}" alt="Preview" style="max-height:360px;max-width:100%;object-fit:contain">`;
}

function renderCanvasToPreview(boxId, canvas) {
  const box = document.getElementById(boxId);
  if (!box) return;
  const img = document.createElement('img');
  img.src = canvas.toDataURL('image/png');
  img.style.cssText = 'max-height:360px;max-width:100%;object-fit:contain';
  box.innerHTML = '';
  box.appendChild(img);
}

function makeThumb(file) {
  return new Promise(res => {
    const fr = new FileReader();
    fr.onload = e => res(e.target.result);
    fr.readAsDataURL(file);
  });
}

function addFileItem(listId, name, size, onRemove) {
  const list = document.getElementById(listId);
  if (!list) return;
  const item = document.createElement('div');
  item.className = 'file-item';
  item.innerHTML = `<div style="width:36px;height:36px;border-radius:6px;background:var(--surface3);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">🖼️</div><div class="file-item-info"><div class="file-item-name">${name}</div><div class="file-item-size">${fmtSize(size)}</div></div><button class="file-item-remove" title="Remove">✕</button>`;
  item.querySelector('.file-item-remove').onclick = () => { item.remove(); if (onRemove) onRemove(); };
  list.appendChild(item);
}

// ===== COMPRESS =====
setupDragDrop('dz-compress','fi-compress', () => {});

async function loadCompressFile(input) {
  if (!input.files[0]) return;
  const file = input.files[0];
  state.compress.origSize = file.size;
  state.compress.img = await loadImageFromFile(file);
  document.getElementById('fl-compress').innerHTML = '';
  addFileItem('fl-compress', file.name, file.size);
  document.getElementById('compress-stats').style.display = 'none';
  document.getElementById('res-compress').classList.remove('show');
  document.getElementById('compare-compress').style.display = 'none';
  document.getElementById('rw-compress').style.display = 'none';
}

function updateQualityLabel(v) {
  document.getElementById('quality-val').textContent = v + '%';
}

async function runCompress() {
  if (!state.compress.img) { toast('Please upload an image first.','error'); return; }
  showProcessing('proc-compress', true);
  const progWrap = document.getElementById('prog-compress');
  progWrap.style.display = 'block';
  setProgress('pf-compress', 30);
  await new Promise(r => setTimeout(r, 50));
  setProgress('pf-compress', 70);

  const img = state.compress.img;
  const quality = document.getElementById('quality-slider').value / 100;
  const cv = document.getElementById('cv-compress');
  cv.width = img.naturalWidth;
  cv.height = img.naturalHeight;
  const ctx = cv.getContext('2d');
  ctx.drawImage(img, 0, 0);
  setProgress('pf-compress', 90);

  const blob = await canvasToBlob(cv, 'image/jpeg', quality);
  const newSize = blob.size;
  const saved = state.compress.origSize - newSize;
  const pct = Math.max(0, ((saved / state.compress.origSize) * 100)).toFixed(1);

  setProgress('pf-compress', 100);
  showProcessing('proc-compress', false);
  setTimeout(() => { progWrap.style.display = 'none'; setProgress('pf-compress',0); }, 600);

  const stats = document.getElementById('compress-stats');
  stats.style.display = 'grid';
  document.getElementById('cs-orig').textContent = fmtSize(state.compress.origSize);
  document.getElementById('cs-new').textContent = fmtSize(newSize);
  document.getElementById('cs-saved').textContent = saved > 0 ? fmtSize(saved) : '0 B';
  document.getElementById('cs-pct').textContent = pct + '%';

  // before/after
  const beforeImg = document.getElementById('compare-before-compress');
  const afterImg = document.getElementById('compare-after-img-compress');
  beforeImg.src = img.src;
  afterImg.src = cv.toDataURL('image/jpeg', quality);
  document.getElementById('compare-compress').style.display = 'block';
  document.getElementById('rw-compress').style.display = 'none';
  initCompareSlider('cw-compress','ca-compress','cd-compress');
  showResult('res-compress');
  toast('Compressed! Saved ' + pct + '%','success');
}

function initCompareSlider(wrapId, afterId, divId) {
  const wrap = document.getElementById(wrapId);
  const after = document.getElementById(afterId);
  const div = document.getElementById(divId);
  if (!wrap || !after || !div) return;
  let dragging = false;
  function move(pct) {
    pct = Math.max(0, Math.min(100, pct));
    div.style.left = pct + '%';
    after.style.clipPath = `inset(0 ${100-pct}% 0 0)`;
  }
  move(50);
  function getX(e) { return e.touches ? e.touches[0].clientX : e.clientX; }
  div.addEventListener('mousedown', e => { dragging = true; e.preventDefault(); });
  div.addEventListener('touchstart', e => { dragging = true; }, {passive:true});
  window.addEventListener('mouseup', () => dragging = false);
  window.addEventListener('touchend', () => dragging = false);
  window.addEventListener('mousemove', e => { if (!dragging) return; const r = wrap.getBoundingClientRect(); move(((getX(e)-r.left)/r.width)*100); });
  window.addEventListener('touchmove', e => { if (!dragging) return; const r = wrap.getBoundingClientRect(); move(((getX(e)-r.left)/r.width)*100); }, {passive:true});
}

// ===== RESIZE =====
setupDragDrop('dz-resize','fi-resize', () => {});

async function loadSinglePreview(input, prevId, infoId) {
  if (!input.files[0]) return;
  const file = input.files[0];
  const img = await loadImageFromFile(file);
  state.resize.img = img;
  state.resize.origW = img.naturalWidth;
  state.resize.origH = img.naturalHeight;
  document.getElementById('rz-w').value = img.naturalWidth;
  document.getElementById('rz-h').value = img.naturalHeight;
  const dataUrl = await readFileAsDataURL(file);
  setPreviewImg(prevId, dataUrl);
  if (infoId) document.getElementById(infoId).textContent = `${img.naturalWidth}×${img.naturalHeight}px · ${fmtSize(file.size)}`;
  document.getElementById('res-resize').classList.remove('show');
}

function lockAspect(changed) {
  if (!document.getElementById('rz-lock').checked) return;
  const { origW, origH } = state.resize;
  if (!origW || !origH) return;
  const ratio = origW / origH;
  if (changed === 'w') {
    const w = parseInt(document.getElementById('rz-w').value) || 0;
    document.getElementById('rz-h').value = Math.round(w / ratio);
  } else {
    const h = parseInt(document.getElementById('rz-h').value) || 0;
    document.getElementById('rz-w').value = Math.round(h * ratio);
  }
}

function runResize() {
  if (!state.resize.img) { toast('Please upload an image first.','error'); return; }
  const w = parseInt(document.getElementById('rz-w').value);
  const h = parseInt(document.getElementById('rz-h').value);
  if (!w || !h || w < 1 || h < 1) { toast('Enter valid width and height.','error'); return; }
  const cv = document.getElementById('cv-resize');
  cv.width = w; cv.height = h;
  const ctx = cv.getContext('2d');
  ctx.drawImage(state.resize.img, 0, 0, w, h);
  setPreviewImg('prev-resize', cv.toDataURL('image/png'));
  showResult('res-resize');
  toast(`Resized to ${w}×${h}px`,'success');
}

// ===== CONVERT =====
setupDragDrop('dz-convert','fi-convert', () => {});

async function loadConvertFiles(input) {
  state.convert.files = Array.from(input.files);
  const list = document.getElementById('fl-convert');
  list.innerHTML = '';
  state.convert.files.forEach((f, i) => addFileItem('fl-convert', f.name, f.size, () => { state.convert.files.splice(i,1); }));
  document.getElementById('res-convert').classList.remove('show');
  document.getElementById('conv-results').innerHTML = '';
  toast(`${state.convert.files.length} file(s) loaded`,'info');
}

function setFormat(fmt, el) {
  state.convert.format = fmt;
  document.querySelectorAll('#fmt-group .radio-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

async function runConvert() {
  if (!state.convert.files.length) { toast('Please upload images first.','error'); return; }
  const fmt = state.convert.format;
  const quality = document.getElementById('conv-q-slider').value / 100;
  const mimeMap = {jpg:'image/jpeg',png:'image/png',webp:'image/webp'};
  const mime = mimeMap[fmt];
  const resultsEl = document.getElementById('conv-results');
  resultsEl.innerHTML = '<div style="color:var(--text3);font-size:.85rem;margin-bottom:10px">Converted files ready for download:</div>';
  showResult('res-convert');

  for (const file of state.convert.files) {
    try {
      const img = await loadImageFromFile(file);
      const cv = document.createElement('canvas');
      cv.width = img.naturalWidth; cv.height = img.naturalHeight;
      const ctx = cv.getContext('2d');
      if (fmt === 'jpg') { ctx.fillStyle = '#fff'; ctx.fillRect(0,0,cv.width,cv.height); }
      ctx.drawImage(img, 0, 0);
      const dataUrl = cv.toDataURL(mime, quality);
      const newName = file.name.replace(/\.[^.]+$/, '') + '.' + fmt;
      const row = document.createElement('div');
      row.className = 'file-item';
      row.style.marginBottom = '6px';
      row.innerHTML = `<img src="${dataUrl}" class="file-item-thumb" alt=""><div class="file-item-info"><div class="file-item-name">${newName}</div></div><a href="${dataUrl}" download="${newName}" class="btn btn-success btn-sm">⬇️ Save</a>`;
      resultsEl.appendChild(row);
    } catch(e) {
      toast('Failed to convert ' + file.name,'error');
    }
  }
  toast('All files converted!','success');
}

// ===== CROP =====
setupDragDrop('dz-crop','fi-crop', () => {});

async function loadCropFile(input) {
  if (!input.files[0]) return;
  const file = input.files[0];
  const img = await loadImageFromFile(file);
  state.crop.img = img;
  const container = document.getElementById('crop-container');
  const placeholder = document.getElementById('crop-placeholder');
  const cropImg = document.getElementById('crop-img');
  cropImg.src = img.src || URL.createObjectURL(input.files[0]);
  await readFileAsDataURL(file).then(d => { cropImg.src = d; });
  placeholder.style.display = 'none';
  container.style.display = 'inline-block';
  document.getElementById('res-crop').classList.remove('show');
  document.getElementById('crop-sel').style.display = 'none';
  setTimeout(() => initCropDrag(), 100);
}

function initCropDrag() {
  const container = document.getElementById('crop-container');
  const sel = document.getElementById('crop-sel');
  const img = document.getElementById('crop-img');
  let dragging = false, startX, startY;

  function getPos(e) {
    const r = container.getBoundingClientRect();
    const cx = e.touches ? e.touches[0].clientX : e.clientX;
    const cy = e.touches ? e.touches[0].clientY : e.clientY;
    return { x: cx - r.left, y: cy - r.top };
  }

  container.onmousedown = container.ontouchstart = e => {
    e.preventDefault();
    const p = getPos(e);
    startX = p.x; startY = p.y;
    dragging = true;
    sel.style.display = 'block';
    sel.style.left = startX + 'px'; sel.style.top = startY + 'px';
    sel.style.width = '0px'; sel.style.height = '0px';
  };
  window.onmousemove = window.ontouchmove = e => {
    if (!dragging) return;
    const p = getPos(e);
    const x = Math.min(startX, p.x), y = Math.min(startY, p.y);
    const w = Math.abs(p.x - startX), h = Math.abs(p.y - startY);
    sel.style.left = x + 'px'; sel.style.top = y + 'px';
    sel.style.width = w + 'px'; sel.style.height = h + 'px';
    const scaleX = state.crop.img.naturalWidth / img.offsetWidth;
    const scaleY = state.crop.img.naturalHeight / img.offsetHeight;
    state.crop.sel = { x: Math.round(x*scaleX), y: Math.round(y*scaleY), w: Math.round(w*scaleX), h: Math.round(h*scaleY) };
    document.getElementById('crop-x').value = state.crop.sel.x;
    document.getElementById('crop-y').value = state.crop.sel.y;
    document.getElementById('crop-w').value = state.crop.sel.w;
    document.getElementById('crop-h').value = state.crop.sel.h;
  };
  window.onmouseup = window.ontouchend = () => { dragging = false; };
}

function updateCropManual() {
  state.crop.sel.x = parseInt(document.getElementById('crop-x').value)||0;
  state.crop.sel.y = parseInt(document.getElementById('crop-y').value)||0;
  state.crop.sel.w = parseInt(document.getElementById('crop-w').value)||0;
  state.crop.sel.h = parseInt(document.getElementById('crop-h').value)||0;
}

function runCrop() {
  if (!state.crop.img) { toast('Please upload an image first.','error'); return; }
  const { x, y, w, h } = state.crop.sel;
  if (!w || !h) { toast('Draw a crop area on the image.','error'); return; }
  const cv = document.getElementById('cv-crop');
  cv.width = w; cv.height = h;
  const ctx = cv.getContext('2d');
  ctx.drawImage(state.crop.img, x, y, w, h, 0, 0, w, h);
  document.getElementById('crop-preview-out').src = cv.toDataURL('image/png');
  showResult('res-crop');
  toast(`Cropped to ${w}×${h}px`,'success');
}

// ===== ROTATE =====
setupDragDrop('dz-rotate','fi-rotate', () => {});

async function loadRotateFile(input) {
  if (!input.files[0]) return;
  const file = input.files[0];
  state.rotate.img = await loadImageFromFile(file);
  state.rotate.angle = 0;
  const d = await readFileAsDataURL(file);
  setPreviewImg('prev-rotate', d);
  document.getElementById('res-rotate').classList.remove('show');
  document.getElementById('rot-angle').value = 0;
  document.getElementById('rot-angle-val').textContent = '0°';
}

function applyRotate(deg) {
  if (!state.rotate.img) { toast('Please upload an image first.','error'); return; }
  state.rotate.angle = (state.rotate.angle + deg) % 360;
  drawRotated(state.rotate.angle);
}

function applyCustomRotate() {
  if (!state.rotate.img) { toast('Please upload an image first.','error'); return; }
  const angle = parseFloat(document.getElementById('rot-angle').value) || 0;
  state.rotate.angle = angle;
  drawRotated(angle);
}

function drawRotated(angle) {
  const img = state.rotate.img;
  const rad = angle * Math.PI / 180;
  const sin = Math.abs(Math.sin(rad)), cos = Math.abs(Math.cos(rad));
  const w = Math.round(img.naturalWidth * cos + img.naturalHeight * sin);
  const h = Math.round(img.naturalWidth * sin + img.naturalHeight * cos);
  const cv = document.getElementById('cv-rotate');
  cv.width = w; cv.height = h;
  const ctx = cv.getContext('2d');
  ctx.translate(w/2, h/2);
  ctx.rotate(rad);
  ctx.drawImage(img, -img.naturalWidth/2, -img.naturalHeight/2);
  renderCanvasToPreview('prev-rotate', cv);
  showResult('res-rotate');
  toast('Rotated ' + angle + '°','success');
}

// ===== FLIP =====
setupDragDrop('dz-flip','fi-flip', () => {});

async function loadFlipFile(input) {
  if (!input.files[0]) return;
  state.flip.img = await loadImageFromFile(input.files[0]);
  const d = await readFileAsDataURL(input.files[0]);
  setPreviewImg('prev-flip', d);
  document.getElementById('res-flip').classList.remove('show');
}

function runFlip(dir) {
  if (!state.flip.img) { toast('Please upload an image first.','error'); return; }
  const img = state.flip.img;
  const cv = document.getElementById('cv-flip');
  cv.width = img.naturalWidth; cv.height = img.naturalHeight;
  const ctx = cv.getContext('2d');
  ctx.save();
  if (dir === 'h') { ctx.scale(-1,1); ctx.drawImage(img, -img.naturalWidth, 0); }
  else { ctx.scale(1,-1); ctx.drawImage(img, 0, -img.naturalHeight); }
  ctx.restore();
  renderCanvasToPreview('prev-flip', cv);
  showResult('res-flip');
  toast(dir === 'h' ? 'Flipped horizontally' : 'Flipped vertically','success');
}

// ===== WATERMARK =====
setupDragDrop('dz-wm','fi-wm', () => {});

async function loadWmFile(input) {
  if (!input.files[0]) return;
  state.watermark.img = await loadImageFromFile(input.files[0]);
  const d = await readFileAsDataURL(input.files[0]);
  setPreviewImg('prev-wm', d);
  document.getElementById('res-wm').classList.remove('show');
}

function runWatermark() {
  if (!state.watermark.img) { toast('Please upload an image first.','error'); return; }
  const img = state.watermark.img;
  const text = document.getElementById('wm-text').value || '© Watermark';
  const size = parseInt(document.getElementById('wm-size').value) || 36;
  const color = document.getElementById('wm-color').value;
  const opacity = document.getElementById('wm-opacity').value / 100;
  const pos = document.getElementById('wm-pos').value;
  const cv = document.getElementById('cv-wm');
  const cvp = document.getElementById('cv-wm-prev');
  cv.width = img.naturalWidth; cv.height = img.naturalHeight;
  cvp.width = Math.min(img.naturalWidth, 800);
  cvp.height = Math.round(img.naturalHeight * (cvp.width / img.naturalWidth));
  const ctx = cv.getContext('2d');
  ctx.drawImage(img, 0, 0);
  ctx.font = `bold ${size}px Inter,sans-serif`;
  ctx.fillStyle = color;
  ctx.globalAlpha = opacity;
  const pad = 20;
  const tw = ctx.measureText(text).width;
  const th = size;
  let x = pad, y = pad + th;
  if (pos === 'br') { x = img.naturalWidth - tw - pad; y = img.naturalHeight - pad; }
  else if (pos === 'bl') { x = pad; y = img.naturalHeight - pad; }
  else if (pos === 'tr') { x = img.naturalWidth - tw - pad; y = th + pad; }
  else if (pos === 'tl') { x = pad; y = th + pad; }
  else if (pos === 'c') { x = (img.naturalWidth - tw)/2; y = (img.naturalHeight + th)/2; }
  else if (pos === 'tile') {
    for (let ty = size + pad; ty < img.naturalHeight; ty += size*3) {
      for (let tx = 0; tx < img.naturalWidth; tx += tw + 40) {
        ctx.fillText(text, tx, ty);
      }
    }
    ctx.globalAlpha = 1;
    const ctxp = cvp.getContext('2d');
    ctxp.drawImage(cv, 0, 0, cvp.width, cvp.height);
    showResult('res-wm');
    toast('Watermark added!','success');
    return;
  }
  ctx.fillText(text, x, y);
  ctx.globalAlpha = 1;
  const ctxp = cvp.getContext('2d');
  ctxp.drawImage(cv, 0, 0, cvp.width, cvp.height);
  showResult('res-wm');
  toast('Watermark added!','success');
}

// ===== MERGE =====
setupDragDrop('dz-merge','fi-merge', () => {});

async function loadMergeFiles(input) {
  state.merge.images = [];
  document.getElementById('fl-merge').innerHTML = '';
  for (const file of Array.from(input.files)) {
    const img = await loadImageFromFile(file);
    state.merge.images.push(img);
    addFileItem('fl-merge', file.name, file.size);
  }
  toast(`${state.merge.images.length} image(s) loaded`,'info');
  document.getElementById('res-merge').classList.remove('show');
}

function setMergeDir(dir, el) {
  state.merge.dir = dir;
  document.querySelectorAll('#merge-dir-group .radio-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

function runMerge() {
  if (state.merge.images.length < 2) { toast('Upload at least 2 images.','error'); return; }
  const imgs = state.merge.images;
  const gap = parseInt(document.getElementById('merge-gap').value) || 0;
  const bg = document.getElementById('merge-bg').value;
  const dir = state.merge.dir;
  const cv = document.getElementById('cv-merge');
  let totalW = 0, totalH = 0;
  if (dir === 'horizontal') {
    totalW = imgs.reduce((s,i) => s + i.naturalWidth, 0) + gap * (imgs.length-1);
    totalH = Math.max(...imgs.map(i => i.naturalHeight));
  } else {
    totalW = Math.max(...imgs.map(i => i.naturalWidth));
    totalH = imgs.reduce((s,i) => s + i.naturalHeight, 0) + gap * (imgs.length-1);
  }
  cv.width = totalW; cv.height = totalH;
  const ctx = cv.getContext('2d');
  ctx.fillStyle = bg; ctx.fillRect(0,0,totalW,totalH);
  let offset = 0;
  for (const img of imgs) {
    if (dir === 'horizontal') { ctx.drawImage(img, offset, 0); offset += img.naturalWidth + gap; }
    else { ctx.drawImage(img, 0, offset); offset += img.naturalHeight + gap; }
  }
  const box = document.getElementById('prev-merge');
  const previewImg = document.createElement('img');
  previewImg.src = cv.toDataURL('image/png');
  previewImg.style.cssText = 'max-height:380px;max-width:100%;object-fit:contain';
  box.innerHTML = '';
  box.appendChild(previewImg);
  showResult('res-merge');
  toast('Images merged!','success');
}

// ===== PDF TO IMAGE =====
let pdfFmt = 'jpg';
function setPdfFmt(fmt, el) {
  pdfFmt = fmt;
  document.querySelectorAll('#pdf-fmt-group .radio-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

async function loadPdfFile(input) {
  if (!input.files[0]) return;
  const file = input.files[0];
  document.getElementById('pdf-pages').innerHTML = '';
  document.getElementById('res-pdf').classList.remove('show');
  const progWrap = document.getElementById('prog-pdf');
  const procEl = document.getElementById('proc-pdf');
  procEl.classList.add('active');
  progWrap.style.display = 'block';
  setProgress('pf-pdf',10);

  loadPdfJS(async () => {
    try {
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({data: arrayBuffer}).promise;
      const numPages = pdf.numPages;
      const scale = parseFloat(document.getElementById('pdf-scale').value) || 2;
      const mime = pdfFmt === 'png' ? 'image/png' : 'image/jpeg';
      const ext = pdfFmt;
      const pagesEl = document.getElementById('pdf-pages');
      pagesEl.innerHTML = `<div style="font-size:.82rem;color:var(--text3);margin-bottom:10px">${numPages} page(s) found. Rendering…</div>`;
      showResult('res-pdf');

      for (let i = 1; i <= numPages; i++) {
        const page = await pdf.getPage(i);
        const vp = page.getViewport({scale});
        const cv = document.createElement('canvas');
        cv.width = vp.width; cv.height = vp.height;
        const ctx = cv.getContext('2d');
        if (pdfFmt === 'jpg') { ctx.fillStyle='#fff'; ctx.fillRect(0,0,vp.width,vp.height); }
        await page.render({canvasContext: ctx, viewport: vp}).promise;
        const dataUrl = cv.toDataURL(mime, 0.92);
        const row = document.createElement('div');
        row.style.marginBottom = '12px';
        row.className = 'file-item';
        const previewThumb = document.createElement('img');
        previewThumb.src = dataUrl;
        previewThumb.style.cssText = 'width:60px;height:60px;object-fit:contain;border-radius:6px;background:var(--surface3)';
        const info = document.createElement('div');
        info.className = 'file-item-info';
        info.innerHTML = `<div class="file-item-name">Page ${i} of ${numPages}</div><div class="file-item-size">${vp.width}×${vp.height}px</div>`;
        const a = document.createElement('a');
        a.href = dataUrl;
        a.download = `page-${i}.${ext}`;
        a.className = 'btn btn-success btn-sm';
        a.textContent = '⬇️ Save';
        row.appendChild(previewThumb);
        row.appendChild(info);
        row.appendChild(a);
        pagesEl.appendChild(row);
        setProgress('pf-pdf', Math.round((i/numPages)*90)+10);
        document.getElementById('pt-pdf').textContent = `Page ${i}/${numPages}`;
      }
      setProgress('pf-pdf',100);
      setTimeout(() => { progWrap.style.display='none'; document.getElementById('pt-pdf').textContent=''; setProgress('pf-pdf',0); }, 800);
      procEl.classList.remove('active');
      toast(`${numPages} page(s) converted!`,'success');
    } catch(e) {
      procEl.classList.remove('active');
      progWrap.style.display='none';
      toast('Failed to read PDF. Is it a valid PDF file?','error');
    }
  });
}

// ===== IMAGE TO PDF =====
let i2pOrient = 'portrait';
let i2pImages = [];

function setI2POrient(dir, el) {
  i2pOrient = dir;
  document.querySelectorAll('#i2p-orient-group .radio-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

async function loadI2PFiles(input) {
  i2pImages = [];
  document.getElementById('fl-i2p').innerHTML = '';
  document.getElementById('res-i2p').classList.remove('show');
  const box = document.getElementById('prev-i2p');
  box.innerHTML = '';
  for (const file of Array.from(input.files)) {
    const img = await loadImageFromFile(file);
    const d = await readFileAsDataURL(file);
    i2pImages.push({img, name: file.name, size: file.size, dataUrl: d});
    addFileItem('fl-i2p', file.name, file.size);
    // mini preview
    const thumb = document.createElement('img');
    thumb.src = d;
    thumb.style.cssText = 'max-height:80px;margin:4px;border-radius:6px;border:1px solid var(--border)';
    box.appendChild(thumb);
  }
  toast(`${i2pImages.length} image(s) loaded`,'info');
}

let i2pPdfDataUrl = null;

function runI2P() {
  if (!i2pImages.length) { toast('Please upload images first.','error'); return; }
  loadJsPDF(() => {
    try {
      const pageSz = document.getElementById('i2p-page').value;
      const orient = i2pOrient === 'portrait' ? 'p' : 'l';
      let doc;
      const addPage = (dataUrl, img, first) => {
        const pageW = pageSz === 'fit' ? img.naturalWidth * 0.75 : (pageSz === 'a4' ? 210 : 215.9);
        const pageH = pageSz === 'fit' ? img.naturalHeight * 0.75 : (pageSz === 'a4' ? 297 : 279.4);
        const finalW = orient === 'p' ? pageW : pageH;
        const finalH = orient === 'p' ? pageH : pageW;
        if (first) {
          doc = new jsPDFLib.jsPDF({ orientation: pageSz==='fit'?'p':orient, unit:'mm', format: pageSz==='fit'?[finalW,finalH]:pageSz });
        } else {
          doc.addPage(pageSz==='fit'?[finalW,finalH]:pageSz, orient);
        }
        const ratio = Math.min(finalW / img.naturalWidth, finalH / img.naturalHeight);
        const iw = img.naturalWidth * ratio;
        const ih = img.naturalHeight * ratio;
        const ix = (finalW - iw) / 2;
        const iy = (finalH - ih) / 2;
        doc.addImage(dataUrl, 'JPEG', ix, iy, iw, ih);
      };
      i2pImages.forEach((item, idx) => addPage(item.dataUrl, item.img, idx===0));
      i2pPdfDataUrl = doc.output('datauristring');
      showResult('res-i2p');
      toast('PDF created! Click download.','success');
    } catch(e) {
      toast('Failed to create PDF: ' + e.message,'error');
    }
  });
}

function downloadI2P() {
  if (!i2pPdfDataUrl) { toast('Create the PDF first.','error'); return; }
  const a = document.createElement('a');
  a.href = i2pPdfDataUrl;
  a.download = 'images.pdf';
  a.click();
  toast('PDF downloaded!','success');
}

// ===== INIT DRAG DROPS =====
['dz-compress','dz-resize','dz-convert','dz-crop','dz-rotate','dz-flip','dz-wm','dz-merge'].forEach(id => {
  const inputId = 'fi-' + id.replace('dz-','');
  setupDragDrop(id, inputId, () => {});
});

// Initialize PDF drag drops
['pdf','i2p'].forEach(id => {
  const dzId = 'dz-' + id;
  const el = document.getElementById(dzId);
  if (!el) return;
  const inputId = 'fi-' + id;
  el.addEventListener('dragover', e => { e.preventDefault(); el.classList.add('drag-over'); });
  el.addEventListener('dragleave', () => el.classList.remove('drag-over'));
  el.addEventListener('drop', e => {
    e.preventDefault(); el.classList.remove('drag-over');
    const inp = document.getElementById(inputId);
    if (!inp) return;
    const dt = new DataTransfer();
    Array.from(e.dataTransfer.files).forEach(f => dt.items.add(f));
    inp.files = dt.files;
    inp.dispatchEvent(new Event('change'));
  });
});

// Missing dropzone ids for pdf
const dzPdf = document.getElementById('fi-pdf');
if (dzPdf) {
  const wrap = dzPdf.closest('.dropzone');
  if (wrap) {
    wrap.id = 'dz-pdf';
    wrap.addEventListener('dragover', e => { e.preventDefault(); wrap.classList.add('drag-over'); });
    wrap.addEventListener('dragleave', () => wrap.classList.remove('drag-over'));
    wrap.addEventListener('drop', e => {
      e.preventDefault(); wrap.classList.remove('drag-over');
      const dt = new DataTransfer();
      Array.from(e.dataTransfer.files).forEach(f => dt.items.add(f));
      dzPdf.files = dt.files;
      dzPdf.dispatchEvent(new Event('change'));
    });
  }
}

// ===== DROPZONE CLICK HANDLERS =====
document.querySelectorAll('.dropzone').forEach(dz => {
  const inp = dz.querySelector('input[type=file]');
  if (!inp) return;
  dz.addEventListener('click', () => inp.click());
  dz.addEventListener('keydown', e => { if (e.key==='Enter'||e.key===' ') inp.click(); });
});
</script>
</body>
</html>

